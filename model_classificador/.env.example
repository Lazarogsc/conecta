# ───────────────────────────────────────────────────────────────────────
# Conecta — exemplo de variáveis de ambiente
# Copie este arquivo para ".env" e ajuste os valores. NUNCA versione o .env.
# ───────────────────────────────────────────────────────────────────────

# Chave usada para assinar as sessões do Flask. Em uso real, gere uma chave
# longa e aleatória, por exemplo com:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-longa

# Caminho do banco de dados (opcional). Por padrão usa SQLite local em database.db.
# DATABASE_URL=sqlite:///database.db

# Modo debug do Flask (apenas em desenvolvimento). 1 = ligado, 0 = desligado.
FLASK_DEBUG=0
